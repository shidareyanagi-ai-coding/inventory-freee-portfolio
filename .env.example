# =============================================================================
# .env.example — 変数名とプレースホルダのみ（実値は絶対にコミットしない）
# 使い方: このファイルを .env にコピーして実値を埋める（.env は .gitignore 済み）
#   PowerShell: Copy-Item .env.example .env
# =============================================================================

# --- アプリ共通 -------------------------------------------------------------
APP_ENV=development                 # development | production

# 旧 stdlib サーバ用ポート（A-1 で FastAPI に統合予定）
INVENTORY_HOST=127.0.0.1
INVENTORY_PORT=8000
PSEUDO_FREEE_HOST=127.0.0.1
PSEUDO_FREEE_PORT=8010

# --- A-2: データベース（Neon Postgres） ------------------------------------
# 例: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# --- A-3: 認証（Clerk） -----------------------------------------------------
CLERK_PUBLISHABLE_KEY=              # pk_test_xxx / pk_live_xxx（公開キー。ブラウザに出してOK）
CLERK_SECRET_KEY=                   # sk_xxx（秘密キー。サーバ側のみ。ブラウザに出さない）
CLERK_ISSUER=                       # 例: https://xxxx.clerk.accounts.dev
CLERK_JWKS_URL=                     # 例: https://xxxx.clerk.accounts.dev/.well-known/jwks.json
                                    # （未設定でも CLERK_ISSUER から自動導出する）

# Clerk 未設定でもローカルで動かす開発モード（本番=APP_ENV=production では強制 false）。
# true のとき: Authorization 無しのリクエストを既定の dev ユーザとして扱い、
#   X-Dev-User-Id ヘッダで別テナントを切替えられる（テナント分離テスト用）。
AUTH_DEV_MODE=false

# --- A-3: テスト用DB（本番Neonと必ず分離する。test_postgres.py はDROPする）-----
# 本番とは別の DATABASE_URL（Neonのテスト用ブランチ等）をここに入れ、
#   $env:DATABASE_URL = $env:TEST_DATABASE_URL; pytest のように向け替えて検証する。
TEST_DATABASE_URL=

# --- 擬似 freee 連携（本物 freee OAuth は公開用では後回し可） ---------------
PSEUDO_FREEE_API_URL=http://127.0.0.1:8010

# --- A-5: 経費キャプチャ（AI証憑入力 / Claude API） -------------------------
# サーバ側からのみ使用。ブラウザには絶対に出さない。
ANTHROPIC_API_KEY=

# --- 証憑画像ストレージ（S3互換 / Cloudflare R2 / Supabase Storage） --------
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
